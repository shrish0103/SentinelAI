APP_NAME=SentinelAI
APP_ENV=development

MODEL_PROVIDER=openrouter
MODEL_NAME=openai/gpt-4o-mini
API_KEY=replace-with-provider-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://localhost:11434
RESUME_CONTEXT=Shrish is a backend engineer focused on FastAPI, microservices, distributed systems, observability, and applied AI.

OWNER_TELEGRAM_IDS=123456789,987654321
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

HEALTH_TIMEOUT_SECONDS=3
SERVICE_TARGETS_JSON={"api":"http://localhost:8000","telegram":"telegram://bot","llm":"provider://active"}
LOG_LEVEL=INFO